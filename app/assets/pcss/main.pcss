* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;

  font-family: 'Inter', sans-serif;
  color: #fff;
  font-size: 14px;
}

html, body {
  margin: 0;
  padding: 0;
  height: 100vh;
  background: linear-gradient(180deg, #143F70 0%, #283F58 39.9%, #335F91 100%) fixed;
}

body::before {
  content: "";
  position: fixed;
  inset: 0;
  z-index: -1;

  background: linear-gradient(
    180deg,
    #143F70 0%,
    #283F58 39.9%,
    #335F91 100%
  );
}

.app-wrapper {
  min-height: 100vh;
}